{
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "http://127.0.0.1:8000/api/$1"
        },
        {
            "source": "/uploads/(.*)",
            "destination": "http://127.0.0.1:8000/uploads/$1"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}