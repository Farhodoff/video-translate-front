{
    "framework": "vite",
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "https://video-translate-production.up.railway.app/api/$1"
        },
        {
            "source": "/uploads/(.*)",
            "destination": "https://video-translate-production.up.railway.app/uploads/$1"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}